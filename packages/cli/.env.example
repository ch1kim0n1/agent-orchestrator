# Agent Orchestrator — CLI Environment Variables
#
# Copy to .env or set in your shell (e.g. via direnv). The CLI reads
# these at runtime; they're not auto-loaded from a file unless you use
# direnv or source the file manually.
#
# IMPORTANT: never commit real secrets.

# Public URL the dashboard is reachable at (used for notification links,
# `ao status` output, etc.). Defaults to http://localhost:<port>.
# AO_PUBLIC_URL=https://ao.example.com

# Default project ID for `ao spawn` when not passed via --project flag.
# AO_PROJECT_ID=my-app

# Agent / tracker API tokens — typically set in the user's shell
# environment because they're forwarded into agent sessions.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GITHUB_TOKEN=
# LINEAR_API_KEY=
# GITLAB_TOKEN=

# Notifier tokens
# SLACK_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
# OPENCLAW_HOOKS_TOKEN=

# Composio (optional integration platform)
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=
# COMPOSIO_ENTITY_ID=

# Optional: override the config path
# AO_CONFIG_PATH=agent-orchestrator.prod.yaml
