# Agent Orchestrator — Environment Variables
#
# Copy to .env (root) or the relevant package .env file and fill in values.
# Next.js auto-loads .env.local in dev; for production see
# packages/web/.env.production.example (shipped in PR #103 for #79).
#
# IMPORTANT: never commit real secrets. Use your deployment platform's
# secret manager (Docker secrets, Kubernetes secrets, AWS SSM, etc.).
#
# Variables marked (public) are exposed to the browser bundle by Next.js
# via the NEXT_PUBLIC_ prefix — safe to commit defaults, never put
# secrets in NEXT_PUBLIC_ vars.

# ── Web dashboard (packages/web/) ─────────────────────────────────────
# Terminal server ports (14800 range chosen to avoid conflicts with dev tools)
TERMINAL_PORT=14800
DIRECT_TERMINAL_PORT=14801
# (public) — exposed to browser for WebSocket connection
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801
# Optional: override the terminal WebSocket path (defaults to /ws)
# TERMINAL_WS_PATH=/ws
# NEXT_PUBLIC_TERMINAL_WS_PATH=/ws

# ── CLI (packages/cli/) ───────────────────────────────────────────────
# Public URL the dashboard is reachable at (used for notification links,
# `ao status` output, etc.). Defaults to http://localhost:<port>.
# AO_PUBLIC_URL=https://ao.example.com

# Default project ID for `ao spawn` when not passed via --project flag.
# AO_PROJECT_ID=my-app

# ── SCM webhook secrets ───────────────────────────────────────────────
# Referenced by agent-orchestrator.yaml as `secretEnvVar: <NAME>`.
# Must match the secret configured in your SCM provider's webhook settings.
GITHUB_WEBHOOK_SECRET=
# GITLAB_WEBHOOK_SECRET=

# ── Agent / tracker API tokens ────────────────────────────────────────
# These are typically set in the user's shell environment (e.g. via
# direnv) rather than in .env, because they're forwarded into agent
# sessions. Listed here for discoverability — uncomment the ones you use.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GITHUB_TOKEN=
# LINEAR_API_KEY=
# GITLAB_TOKEN=

# ── Notifier tokens ───────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
# OPENCLAW_HOOKS_TOKEN=

# ── Composio (optional integration platform) ──────────────────────────
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=
# COMPOSIO_ENTITY_ID=

# ── Error monitoring (optional) ───────────────────────────────────────
# Sentry DSN for production crash reporting. If unset, the dashboard
# falls back to the local ~/.agent-orchestrator/error.log file (see
# logFatal in packages/core/src/error-log.ts).
# SENTRY_DSN=

# ── Config path override (optional) ───────────────────────────────────
# Point at a non-default config file (e.g. the production template from
# agent-orchestrator.prod.yaml.example).
# AO_CONFIG_PATH=agent-orchestrator.prod.yaml
